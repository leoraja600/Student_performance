# Environment Variables - Backend

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/student_performance_db"

# ============================================================
# JWT AUTHENTICATION
# ============================================================
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# ============================================================
# SERVER
# ============================================================
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# ============================================================
# DEFAULT ADMIN USER (used by seed script)
# ============================================================
ADMIN_EMAIL="admin@college.edu"
ADMIN_PASSWORD="Admin@123456"
ADMIN_NAME="System Admin"

# ============================================================
# LEADERBOARD SCORING FORMULA WEIGHTS (sum should be 100)
# ============================================================
# Formula: (lc_total / LC_MAX) * LC_WEIGHT + (hr_total / HR_MAX) * HR_WEIGHT
LEETCODE_MAX_SCORE=300
LEETCODE_WEIGHT=50
HACKERRANK_MAX_SCORE=500
HACKERRANK_WEIGHT=50

# ============================================================
# SCRAPING / RATE LIMITING
# ============================================================
# Delay in milliseconds between LeetCode requests
LC_REQUEST_DELAY=1500
# Cache HackerRank data for this many minutes before re-scraping
HR_CACHE_TTL_MINUTES=60

# ============================================================
# CRON SCHEDULE (default: every 6 hours)
# ============================================================
CRON_SCHEDULE="0 */6 * * *"
CRON_ENABLED=true

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=info
LOG_DIR=logs
